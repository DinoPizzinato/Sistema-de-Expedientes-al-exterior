32122"><w:rPr><w:highlight w:val="yellow"/></w:rPr><w:t xml:space="preserve"> 7, a cargo del Doctor Enrique V. LAVIE PICO, </w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00732122"><w:rPr><w:highlight w:val="yellow"/></w:rPr><w:t>Secretaria</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="00732122"><w:rPr><w:highlight w:val="yellow"/></w:rPr><w:t xml:space="preserve"> a cargo del Doctor Alejandro Diego CELMA en el marco del Expediente </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00732122"><w:rPr><w:highlight w:val="yellow"/></w:rPr><w:t>Nº</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00732122"><w:rPr><w:highlight w:val="yellow"/></w:rPr><w:t xml:space="preserve"> 912/2026 caratulado: "DNM </w:t></w:r><w:r w:rsidRPr="00732122"><w:rPr><w:highlight w:val="yellow"/></w:rPr><w:t>c/ GARCIA SANCHEZ, BRAYAN STEVEN (EXP. 46688/2017) s/MEDIDAS DE RETENCION"</w:t></w:r><w:r><w:t xml:space="preserve">, quien solicitó cumplimentar la expulsión de nuestro país del ciudadano de nacionalidad </w:t></w:r><w:r w:rsidRPr="00732122"><w:rPr><w:highlight w:val="yellow"/></w:rPr><w:t>colombiana mencionada anteriormente.</w:t></w:r></w:p><w:p w14:paraId="00000004" w14:textId="77777777" w:rsidR="006134E4" w:rsidRDefault="006134E4"><w:pPr><w:spacing w:line="240" w:lineRule="auto"/><w:jc w:val="both"/></w:pPr></w:p><w:p w14:paraId="00000005" w14:textId="77777777" w:rsidR="006134E4" w:rsidRDefault="00DA3B21"><w:pPr><w:spacing w:line="240" w:lineRule="auto"/><w:ind w:right="45"/><w:jc w:val="both"/></w:pPr><w:bookmarkStart w:id="1" w:name="_heading=h.cq1qmpbdwbf3" w:colFirst="0" w:colLast="0"/><w:bookmarkEnd w:id="1"/><w:r><w:t>La Superintendencia de INVESTIGACIONES FEDERALES design</w:t></w:r><w:r><w:t xml:space="preserve">ó para cumplimentar dicha misión al </w:t></w:r><w:r w:rsidRPr="00732122"><w:rPr><w:highlight w:val="yellow"/></w:rPr><w:t xml:space="preserve">Cabo 1º L.P. 38.296 (D.N.I. </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rs